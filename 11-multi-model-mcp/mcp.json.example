{
  "//": "============================================================================",
  "//": ".vscode/mcp.json — Model Context Protocol server configuration",
  "//": "Commit this file. Do NOT commit secret values — use env vars.",
  "//": "Restart VS Code after changes; MCP servers are spawned at startup.",
  "//": "============================================================================",

  "servers": {
    "//-github": "GitHub issues, PRs, code search, workflows",
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${env:GITHUB_TOKEN}"
      }
    },

    "//-filesystem": "Sandboxed file access within the workspace",
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "${workspaceFolder}"
      ]
    },

    "//-kubernetes": "Pods, logs, describe, events. Read-only tools by default.",
    "kubernetes": {
      "command": "npx",
      "args": ["-y", "mcp-server-kubernetes"],
      "env": {
        "KUBECONFIG": "${env:KUBECONFIG}"
      }
    },

    "//-postgres": "Schema + read-only queries. MUST point at a replica, not prod primary.",
    "postgres": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres"],
      "env": {
        "DATABASE_URL": "${env:DB_READONLY_URL}"
      }
    },

    "//-brave-search": "Web search for library docs, error messages, API formats.",
    "brave-search": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-brave-search"],
      "env": {
        "BRAVE_API_KEY": "${env:BRAVE_API_KEY}"
      }
    },

    "//-memory": "Persist small facts across sessions (project conventions, team preferences).",
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"]
    },

    "//-aws-docs": "Search AWS documentation. No auth needed.",
    "aws-docs": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-aws-docs"]
    },

    "//-artifactory": "Internal package registry metadata. Uncomment if you use Artifactory.",
    "artifactory-DISABLED": {
      "command": "npx",
      "args": ["-y", "mcp-server-artifactory"],
      "env": {
        "ARTIFACTORY_URL": "${env:ARTIFACTORY_URL}",
        "ARTIFACTORY_TOKEN": "${env:ARTIFACTORY_TOKEN}"
      }
    },

    "//-slack": "Messages + channels. Remove if your org doesn't want chat context in prompts.",
    "slack-DISABLED": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-slack"],
      "env": {
        "SLACK_BOT_TOKEN": "${env:SLACK_BOT_TOKEN}"
      }
    }
  },

  "//": "----------------------------------------------------------------------",
  "//": "Profile reference — see .github/copilot-mcp-profiles.json",
  "//": "Tools exposed here are further filtered by the active profile.",
  "//": "----------------------------------------------------------------------",
  "profile": "${env:COPILOT_MCP_PROFILE:-read-only}"
}
